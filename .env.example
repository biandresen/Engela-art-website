SITE_URL=http://localhost:3000
CONTEXT=dev
INTEGRATIONS_MODE=safe

# Public fallback contact address shown in the UI and buyer acknowledgement.
# Before engelaart.no email is ready, use a dedicated temporary Engela Art
# address here instead of a personal private address.
VITE_PUBLIC_CONTACT_EMAIL=kontakt@engelaart.no

# Production-only transactional email configuration.
# Temporary pre-domain setup can use the same dedicated temporary receiver.
# If using Resend's onboarding sender before domain verification, keep it
# temporary and switch to an authenticated engelaart.no sender before launch.
INQUIRY_RECEIVER_EMAIL=
INQUIRY_SENDER_EMAIL=
EMAIL_PROVIDER_API_KEY=

# Production-only analytics and monitoring configuration.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
SENTRY_DSN=

VITE_GOOGLE_BUSINESS_PROFILE_URL=
